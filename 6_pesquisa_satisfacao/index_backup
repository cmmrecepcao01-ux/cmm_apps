<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pesquisa de Satisfação - CMM</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700;900&display=swap" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/PapaParse/5.3.2/papaparse.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        :root {
            --bg-main: #0b1116;
            --bg-panel: #121921;
            --border-color: #202c38;
            --color-text: #94a3b8;
            --color-title: #f8fafc;
            --color-green: #22c55e;
            --color-red: #ef4444;
            --color-blue: #3b82f6;
            --color-orange: #f59e0b;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Roboto', sans-serif; }
        
        body { 
            background-color: var(--bg-main); 
            color: var(--color-text); 
            padding: 20px; 
            line-height: 1.6;
        }

        .container { max-width: 1400px; margin: 0 auto; }

        /* HEADER */
        .header {
            display: flex; justify-content: space-between; align-items: center;
            padding: 20px; background-color: var(--bg-panel);
            border: 1px solid var(--border-color); border-radius: 12px; margin-bottom: 20px;
        }
        .header h1 { color: var(--color-title); font-size: 22px; letter-spacing: 1px; }

        /* Estilo dos Novos Botões */
        .header-links { display: flex; gap: 12px; margin-top: 15px; }
        .btn-nav {
            display: inline-flex; align-items: center; gap: 8px;
            padding: 10px 20px; border-radius: 8px; font-size: 11px;
            font-weight: 900; text-decoration: none; color: #fff;
            transition: 0.2s; text-transform: uppercase;
        }
        .btn-bordo { background: #a855f7; border: 1px solid #9333ea; } /* Lilás */
        .btn-bordo:hover { background: #9333ea; transform: scale(1.05); }
        .btn-dados { background: #22c55e; border: 1px solid #16a34a; } /* Verde */
        .btn-dados:hover { background: #16a34a; transform: scale(1.05); }

        /* KPI CARDS */
        .kpi-container { 
            display: grid; 
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); 
            gap: 20px; 
            margin-bottom: 20px; 
        }
        .card {
            background-color: var(--bg-panel); border: 1px solid var(--border-color);
            padding: 20px; border-radius: 12px; text-align: center; cursor: pointer; transition: 0.3s;
            display: flex; flex-direction: column; justify-content: center;
        }
        .card:hover { border-color: var(--color-blue); background: #161f28; }
        .card i { font-size: 28px; margin-bottom: 10px; }
        .card h3 { font-size: 13px; color: var(--color-text); text-transform: uppercase; margin-bottom: 10px; }
        .card .value { font-weight: 900; color: var(--color-title); }
        .card .subtitle { margin-top: 5px; font-weight: bold; }

        /* CHARTS SECTION */
        .main-grid { 
            display: grid; 
            grid-template-columns: 1fr 1fr; /* SIMETRIA PERFEITA PARA OS GRÁFICOS */
            gap: 20px; 
            margin-bottom: 20px;
        }
        
        .chart-box { 
            background-color: var(--bg-panel); 
            border: 1px solid var(--border-color); 
            padding: 20px; 
            border-radius: 12px; 
            height: 450px; 
            position: relative;
        }
        .chart-box.auto-height { height: auto; } /* Para o Assistente IA */
        .chart-box h2 { font-size: 14px; color: var(--color-title); margin-bottom: 20px; text-transform: uppercase; border-left: 3px solid var(--color-blue); padding-left: 10px; }

        /* ASSISTENTE IA */
        .ai-item {
            background-color: rgba(59, 130, 246, 0.05);
            border: 1px solid #1c3656;
            padding: 15px 20px;
            border-radius: 8px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 10px;
            transition: 0.2s;
        }
        .ai-item:hover { background-color: rgba(59, 130, 246, 0.1); border-color: var(--color-blue); }
        .ai-item strong { color: var(--color-title); font-size: 16px; letter-spacing: 0.5px; }
        .ai-badge { 
            background-color: rgba(245, 158, 11, 0.2); 
            color: var(--color-orange); 
            border: 1px solid var(--color-orange);
            padding: 6px 12px; 
            border-radius: 20px; 
            font-weight: 900; 
            font-size: 13px; 
        }

        /* DETAILS LIST */
        .details-container {
            background-color: var(--bg-panel); border: 1px solid var(--border-color);
            padding: 20px; border-radius: 12px; display: none; margin-top: 20px;
        }
        .details-container h2 { font-size: 16px; color: var(--color-title); margin-bottom: 15px; border-left: 3px solid var(--color-green); padding-left: 10px; }
        .opinion-item {
            padding: 15px; border-bottom: 1px solid var(--border-color); display: flex; gap: 20px; align-items: flex-start;
        }
        .stars { color: var(--color-orange); font-size: 14px; min-width: 90px; }
        .opinion-text { color: var(--color-title); font-size: 14px; line-height: 1.4; }
        .opinion-cat { font-size: 10px; background: #202c38; padding: 2px 8px; border-radius: 4px; color: var(--color-blue); margin-top: 5px; display: inline-block; }

        #loader { text-align: center; padding: 100px; font-size: 20px; color: var(--color-blue); }

        @media (max-width: 1000px) {
            .main-grid { grid-template-columns: 1fr; }
            .chart-box { height: 350px; }
        }
    </style>
</head>
<body>

    <div class="container">
        <div id="loader"><i class="fas fa-circle-notch fa-spin"></i> Sincronizando com Base de Dados CMM...</div>

        <div id="dashboard" style="display:none;">
            <header class="header">
                <div>
                    <h1>PESQUISA DE SATISFAÇÃO</h1>
                <div class="header-links">
                    <a href="https://painelbordocmm.netlify.app/" target="_blank" class="btn-nav btn-bordo">
                        <i class="fas fa-desktop"></i> PAINEL DE BORDO CMM
                    </a>
                    <a href="https://docs.google.com/spreadsheets/d/1HXJTLet6gn_MpxDBaQBT9C4ZqBAT1VQCV9VLF9wGrkE/edit?usp=sharing" target="_blank" class="btn-nav btn-dados">
                        <i class="fas fa-database"></i> FONTE DE DADOS
                    </a>
                </div>
                <p style="font-size: 12px; color: var(--color-green); font-weight: bold; margin-top: 10px;"> 
                    <i class="fas fa-check-circle"></i> RESPOSTAS EM TEMPO REAL
                </p>
                </div>
                <div style="text-align: right;">
                    <div id="total-respostas" style="font-size: 22px; font-weight: 900; color: var(--color-title);">0</div>
                    <span style="font-size: 11px; color: var(--color-text);">TOTAL DE AVALIAÇÕES</span>
                </div>
            </header>

            <div class="kpi-container">
                <div class="card" onclick="showDetails('Geral')">
                    <i class="fas fa-star" style="color: var(--color-orange);"></i> <h3>Satisfação Geral</h3>
                    <div class="value" id="media-geral" style="font-size: 26px;">0.0</div>
                    <div class="subtitle" style="font-size: 11px; color: var(--color-blue);">MÉDIA PONDERADA</div>
                </div>
                <div class="card" id="card-melhor" onclick="showDetails('Melhor')">
                    <i class="fas fa-award" style="color: var(--color-green);"></i>
                    <h3>Maior Nota</h3>
                    <div class="value" id="melhor-nome" style="font-size: 26px; line-height: 1.2; margin-bottom: 5px;">---</div>
                    <div class="subtitle" id="melhor-valor" style="font-size: 22px; color: var(--color-green);">NOTA: 0.0</div>
                </div>
                <div class="card" id="card-pior" onclick="showDetails('Pior')">
                    <i class="fas fa-exclamation-triangle" style="color: var(--color-red);"></i>
                    <h3>Menor Nota</h3>
                    <div class="value" id="pior-nome" style="font-size: 26px; line-height: 1.2; margin-bottom: 5px;">---</div>
                    <div class="subtitle" id="pior-valor" style="font-size: 22px; color: var(--color-red);">NOTA: 0.0</div>
                </div>
            </div>

            <div class="main-grid">
                <div class="chart-box">
                    <h2>Desempenho por Categoria</h2>
                    <canvas id="barChart"></canvas>
                </div>
                <div class="chart-box">
                    <h2>Frequência de Críticas/Sugestões</h2>
                    <canvas id="pieChart"></canvas>
                </div>
            </div>

            <div class="chart-box auto-height" style="margin-bottom: 20px;">
                <h2><i class="fas fa-robot" style="color: var(--color-orange); margin-right: 8px;"></i> Assistente de Prioridades (IA CMM)</h2>
                <p style="font-size: 13px; margin-bottom: 15px; color: var(--color-text);">Com base na incidência de palavras-chave nas reclamações dos clientes, o sistema sugere as seguintes melhorias na infraestrutura:</p>
                <div id="ai-suggestions" style="display: flex; flex-direction: column;">
                    </div>
            </div>

            <div class="details-container" id="detailsSection">
                <h2 id="detailsTitle"><i class="fas fa-comments" style="margin-right: 8px;"></i> Detalhamento de Opiniões Abertas</h2>
                <div id="opinionsList">
                    </div>
            </div>
        </div>
    </div>

    <script>
        // Link CSV do seu Google Sheets
        const SHEET_URL = 'https://docs.google.com/spreadsheets/d/1HXJTLet6gn_MpxDBaQBT9C4ZqBAT1VQCV9VLF9wGrkE/export?format=csv';
        
        let allData = [];
        let categorias = [
            "RECEPÇÃO E ATENDIMENTO",
            "COMUNICAÇÃO SOBRE O SERVIÇO",
            "ACOMPANHAMENTO DO SERVIÇO",
            "PRAZO DE ENTREGA",
            "CONDIÇÕES DO LOCAL DE ESPERA",
            "COMUNICAÇÃO COM O CMM",
            "SATISFAÇÃO COM O SERVIÇO"
        ];

        function init() {
            Papa.parse(SHEET_URL, {
                download: true,
                header: true,
                skipEmptyLines: true,
                complete: function(results) {
                    allData = results.data;
                    document.getElementById('loader').style.display = 'none';
                    document.getElementById('dashboard').style.display = 'block';
                    processData(results.data);
                }
            });
        }

        function processData(data) {
            let medias = {};
            let colSugestao = Object.keys(data[0]).find(k => k.includes("SUGESTÃO"));

            categorias.forEach(cat => {
                let col = Object.keys(data[0]).find(k => k.toUpperCase().includes(cat));
                let sum = 0, count = 0;
                data.forEach(row => {
                    let val = parseFloat(row[col]);
                    if(!isNaN(val)) { sum += val; count++; }
                });
                medias[cat] = count > 0 ? (sum / count).toFixed(2) : 0;
            });

            // Atualiza KPIs
            let notas = Object.values(medias).map(Number);
            let mediaFinal = (notas.reduce((a, b) => a + b, 0) / notas.length).toFixed(2);
            document.getElementById('media-geral').innerText = mediaFinal;
            document.getElementById('total-respostas').innerText = data.length;

            let entries = Object.entries(medias).sort((a, b) => b[1] - a[1]);
            
            document.getElementById('melhor-nome').innerText = entries[0][0];
            document.getElementById('melhor-valor').innerText = "NOTA: " + entries[0][1];
            
            document.getElementById('pior-nome').innerText = entries[entries.length-1][0];
            document.getElementById('pior-valor').innerText = "NOTA: " + entries[entries.length-1][1];

            renderCharts(medias, data);
            generateAISuggestions(data, colSugestao); // Chama o assistente
        }

        function renderCharts(medias, rawData) {
            // GRÁFICO DE BARRAS HORIZONTAL
            new Chart(document.getElementById('barChart'), {
                type: 'bar',
                data: {
                    labels: Object.keys(medias),
                    datasets: [{
                        label: 'Nota Média',
                        data: Object.values(medias),
                        backgroundColor: '#3b82f6',
                        borderRadius: 5,
                        barThickness: 20
                    }]
                },
                options: {
                    indexAxis: 'y', 
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: { 
                        x: { beginAtZero: true, max: 5, ticks: { color: '#94a3b8' }, grid: { color: '#202c38' } },
                        y: { ticks: { color: '#f8fafc', font: { size: 10 } }, grid: { display: false } }
                    },
                    plugins: { legend: { display: false } }
                }
            });

            // Categorização de Palavras-Chave para o Gráfico
            let keywords = {
                "Sala de Espera": ["espera", "sala", "conforto", "cadeira"],
                "Café/Bebedouro": ["café", "água", "bebedouro"],
                "Ar Condicionado": ["ar", "calor", "frio", "condicionado"],
                "Instalações/Limpeza": ["banheiro", "limpeza", "instalação", "sujo", "limpo"],
                "Agilidade": ["rápido", "demora", "agilidade", "tempo"]
            };

            let counts = { "Sala de Espera": 0, "Café/Bebedouro": 0, "Ar Condicionado": 0, "Instalações/Limpeza": 0, "Agilidade": 0 };
            let colSugestao = Object.keys(rawData[0]).find(k => k.includes("SUGESTÃO"));

            rawData.forEach(row => {
                let text = (row[colSugestao] || "").toLowerCase();
                Object.keys(keywords).forEach(cat => {
                    if(keywords[cat].some(k => text.includes(k))) counts[cat]++;
                });
            });

            // GRÁFICO CIRCULAR AJUSTADO (Reduzido, font maior)
            new Chart(document.getElementById('pieChart'), {
                type: 'doughnut',
                data: {
                    labels: Object.keys(counts),
                    datasets: [{
                        data: Object.values(counts),
                        backgroundColor: ['#ef4444', '#f59e0b', '#3b82f6', '#22c55e', '#a855f7'],
                        borderWidth: 0
                    }]
                },
                options: { 
                    responsive: true, 
                    maintainAspectRatio: false, 
                    layout: { padding: 15 }, // Reduz o tamanho do gráfico para caber melhor
                    plugins: { 
                        legend: { 
                            position: 'bottom', 
                            labels: { 
                                color: '#f8fafc', // Cor mais clara
                                boxWidth: 15, 
                                font: { size: 13, weight: 'bold' } // Fonte aumentada e negrito
                            } 
                        } 
                    },
                    cutout: '60%' // Deixa o anel mais espesso e a circunferência mais preenchida
                }
            });
        }

        function generateAISuggestions(rawData, colSugestao) {
            // Lógica do Assistente Inteligente
            let suggestions = {
                "Instalar / Consertar Ar Condicionado": ["ar", "calor", "frio", "condicionado", "ventilador", "quente"],
                "Disponibilizar Máquina de Café": ["café", "cafe", "cafezinho", "garrafa"],
                "Instalar Bebedouro / Água Gelada": ["água", "agua", "bebedouro", "gelada"],
                "Melhorar Conforto da Espera (Sofás/Cadeiras)": ["sofá", "sofa", "cadeira", "conforto", "assento", "espera"],
                "Instalar Televisão (TV) na Espera": ["tv", "televisão", "televisao", "tela"],
                "Melhorar Higiene / Banheiros": ["banheiro", "limpeza", "sujo", "limpo", "papel", "higiene"]
            };

            let sugCounts = {};
            Object.keys(suggestions).forEach(k => sugCounts[k] = 0);

            rawData.forEach(row => {
                let text = (row[colSugestao] || "").toLowerCase();
                Object.keys(suggestions).forEach(cat => {
                    if(suggestions[cat].some(k => text.includes(k))) sugCounts[cat]++;
                });
            });

            // Ordena as sugestões pela quantidade de menções
            let sortedSugs = Object.entries(sugCounts).filter(a => a[1] > 0).sort((a,b) => b[1] - a[1]);
            
            let container = document.getElementById('ai-suggestions');
            let html = "";
            
            if(sortedSugs.length > 0) {
                sortedSugs.forEach((item, index) => {
                    html += `
                    <div class="ai-item">
                        <div>
                            <span style="color: var(--color-orange); font-weight: 900; margin-right: 15px; font-size: 18px;">${index + 1}º</span>
                            <strong>${item[0]}</strong>
                        </div>
                        <div class="ai-badge">${item[1]} SOLICITAÇÕES</div>
                    </div>`;
                });
            } else {
                html = `<div style="color: var(--color-green); font-weight: bold; padding: 10px;">Nenhuma solicitação estrutural recorrente no momento. Excelente trabalho!</div>`;
            }
            container.innerHTML = html;
        }

        function showDetails(tipo) {
            const section = document.getElementById('detailsSection');
            const list = document.getElementById('opinionsList');
            section.style.display = 'block';
            list.innerHTML = "";
            
            let colSugestao = Object.keys(allData[0]).find(k => k.includes("SUGESTÃO"));
            let colNota = Object.keys(allData[0]).find(k => k.includes("SATISFAÇÃO"));

            // Mostra as últimas 15 opiniões que não estejam vazias
            allData.filter(r => r[colSugestao] && r[colSugestao].length > 2).reverse().slice(0, 15).forEach(row => {
                let div = document.createElement('div');
                div.className = 'opinion-item';
                div.innerHTML = `
                    <div class="stars">${'★'.repeat(row[colNota])}${'☆'.repeat(5-row[colNota])}</div>
                    <div class="opinion-body">
                        <div class="opinion-text">"${row[colSugestao]}"</div>
                        <div class="opinion-cat">Pesquisa de Satisfação CMM</div>
                    </div>
                `;
                list.appendChild(div);
            });
            section.scrollIntoView({ behavior: 'smooth' });
        }

        init();
    </script>
</body>
</html>