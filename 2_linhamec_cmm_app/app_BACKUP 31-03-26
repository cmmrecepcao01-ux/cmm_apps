      if (vehicle) {
        setB(vehicle.brand);
        setM(vehicle.model);
        setY(vehicle.year);
        setO(vehicle.opm);
        return;
      }
      const prev = allServices.find(
        (s) => s.plate.toUpperCase() === p.toUpperCase()
      );
      if (prev) {
        setB(prev.brand);
        setM(prev.model);
        setY(prev.year);
        setO(prev.opm);
      }
    }
  }, [p, allServices, vehicles]);
