const formatMS = (ms: number) => {
  const x = Math.floor(ms / 1000);
  const ss = x % 60;
  const mm = Math.floor(x / 60) % 60;
  const hh = Math.floor(x / 3600);
  return `${hh.toString().padStart(2, '0')}:${mm
    .toString()
    .padStart(2, '0')}:${ss.toString().padStart(2, '0')}`;
};

