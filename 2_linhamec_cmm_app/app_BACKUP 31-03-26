    'SUBSTITUIÇÃO DE',
    'SUBSTITUIÇÃO DO',
    'SUBSTITUIÇÃO DA',
    'SUBSTITUIR',
    'AJUSTE DE',
    'AJUSTE DO',
    'AJUSTE DA',
    'AJUSTAR',
    'LIMPEZA DE',
    'LIMPEZA DO',
    'LIMPEZA DA',
    'LIMPAR',
    'REVISÃO DE',
    'REVISÃO DO',
    'REVISÃO DA',
    'REVISAR',
    'INSTALAÇÃO DE',
    'INSTALAÇÃO DO',
    'INSTALAÇÃO DA',
    'INSTALAR',
    'REMOÇÃO DE',
    'REMOÇÃO DO',
